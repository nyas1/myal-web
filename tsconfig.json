{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "strict": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "types": [
      "vitepress"
    ]
  },
  "include": [
    "docs/.vitepress/**/*.ts",
    "docs/.vitepress/**/*.mts",
    "docs/.vitepress/**/*.d.ts"
  ]
}
